<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive launcher icon. Folder is `mipmap-anydpi` (no `-v26`
  qualifier) because `minSdk = 31`, so every device that can install
  this app already supports the adaptive-icon container.

  The OS composes the foreground layer over the background colour and
  applies whatever mask the launcher uses (circle, squircle, rounded
  square). Foreground is the full-bleed Aura Health logo PNG; the
  background is the same teal that fills the logo's circle so the icon
  reads as a solid teal disc with the white "A" + ECG mark on top in
  every launcher style.
-->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@color/ic_launcher_background" />
    <foreground android:drawable="@mipmap/ic_launcher_foreground" />
    <!--
        Monochrome layer for Android 13+ themed icons. The launcher
        renders this silhouette tinted to the user's wallpaper accent
        colour. We isolate the white "A" + ECG mark from the source
        artwork by treating the teal background as transparent.
    -->
    <monochrome android:drawable="@mipmap/ic_launcher_monochrome" />
</adaptive-icon>
