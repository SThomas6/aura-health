<?xml version="1.0" encoding="utf-8"?>
<!--
  Certificate hashes published by Google to verify the downloadable-fonts
  provider signature at runtime. Values come from the Compose
  ui-text-google-fonts documentation; they are the public fingerprint of
  the com.google.android.gms content provider and do not need to be kept
  secret.

  `tools:ignore="Typos"` because the values are base64-encoded
  signatures, not English prose — the spell checker flags every base64
  block (hundreds of warnings) and there's nothing to "correct".
-->
<resources xmlns:tools="http://schemas.android.com/tools" tools:ignore="Typos">
    <array name="com_google_android_gms_fonts_certs">
        <item>@array/com_google_android_gms_fonts_certs_dev</item>
        <item>@array/com_google_android_gms_fonts_certs_prod</item>
    </array>
    <string-array name="com_google_android_gms_fonts_certs_dev">
        <item>
            
        </item>
    </string-array>
    <string-array name="com_google_android_gms_fonts_certs_prod">
        <item>
            
        </item>
    </string-array>
</resources>
