<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        Aura brand palette, used by the Android-12 splash-screen theme.
        The teal matches the hero-card gradient primary on Home; the
        dark variant (for `values-night`) drops luminance rather than
        hue so the splash panel still reads behind the raster icon on
        OLED wallpapers.

        The default `purple_*` / `teal_*` / `black` / `white` entries
        the Android Studio template ships with were removed — every
        runtime colour now comes from the Compose `MaterialTheme`
        colour scheme (see `ui/theme/Theme.kt`), so the values/colors.xml
        only needs the splash-screen swatches that the platform reads
        before Compose can run.
    -->
    <color name="aura_brand_teal">#0F6E6E</color>
    <color name="aura_brand_teal_dark">#0A4A4A</color>

    <!--
        Adaptive-launcher-icon background. Sampled directly from the
        teal disc in the source artwork (auraHealthIcon.png) so the
        launcher's masked rendering blends seamlessly with the
        foreground PNG even when the OS clips to a different shape.
    -->
    <color name="ic_launcher_background">#116B6C</color>
</resources>